#
# STATE.a2ml — Project state checkpoint (META-TEMPLATE)
#
# This is the STATE file for rsr-julia-library-template-repo itself.
# When consumed by a new Julia library project, replace {{PLACEHOLDER}}
# tokens and customize sections below for the target project.

[metadata]
project = "rsr-julia-library-template-repo"
version = "0.1.0"
last-updated = "2026-07-01"
status = "active"  # active | paused | archived

[project-context]
name = "rsr-julia-library-template-repo"
purpose = "RSR-compliant repository template for registered Julia libraries — the generic rsr-template-repo scaffolding plus Julia-specific scaffolding (Project.toml [compat] closure, Aqua+JET tests wired into Pkg.test(), Documenter docs, julia-test.yml CI) verified green from birth against docs/flagship-rubric.adoc."
completion-percentage = 60

[position]
phase = "implementation"  # design | implementation | testing | maintenance | archived
maturity = "beta"         # experimental | alpha | beta | production | lts

[route-to-mvp]
milestones = [
  { name = "Fork rsr-template-repo, drop Rust-primary CI (rust-ci.yml)", completion = 100 },
  { name = "Julia scaffolding: Project.toml, src/Widget.jl, test/{runtests,aqua,jet}.jl", completion = 100 },
  { name = "Documenter scaffolding: docs/Project.toml, docs/make.jl, docs/src/index.md", completion = 100 },
  { name = "CI: julia-test.yml + documentation.yml (LTS + stable + nightly-allow-fail)", completion = 100 },
  { name = "Own CLADE/ECOSYSTEM/STATE/META/CLAUDE.md identity (was still rsr-template-repo's)", completion = 100 },
  { name = "Verify green-from-birth: Pkg.test(), Aqua, JET, docs build all run clean", completion = 0 },
  { name = "Register in gv-clade-index verisim/seed/repos.a2ml (new entry, separate from this PR)", completion = 0 },
  { name = "Registry-readiness checklist doc (adapted from Axiom.jl's REGISTRY-READINESS.md)", completion = 0 },
]

[blockers-and-issues]
# No active blockers

[critical-next-actions]
actions = [
  "Run julia --project=. -e 'using Pkg; Pkg.instantiate(); Pkg.test()' and fix anything red",
  "Register this repo's clade entry in gv-clade-index (currently only in this repo's own CLADE.a2ml)",
]

[maintenance-status]
last-run-utc = "never"
last-report = "docs/reports/maintenance/latest.json"
last-result = "unknown"  # unknown | pass | warn | fail
open-warnings = 0
open-failures = 0

[ecosystem]
part-of = ["RSR Framework", "hyperpolymath Julia ecosystem"]
depends-on = ["rsr-template-repo", "stapeln", "selur-compose", "cerro-torre", "svalinn", "vordr", "k9-svc"]

# ---------------------------------------------------------------------------
# NOTE FOR CONSUMERS: When using this template to create a new Julia library
# repo, reset the fields above to your project's values and replace all
# {{PLACEHOLDER}} tokens. The milestones above describe the TEMPLATE's
# evolution, not yours.
# ---------------------------------------------------------------------------
